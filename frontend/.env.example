# Copy this file to .env.local before running `npm run dev`.

# Backend API base URL (the demo backend serves this)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# Image proxy (next/image remotePatterns)
NEXT_PUBLIC_API_IMAGES_PROTOCOL=http
NEXT_PUBLIC_API_IMAGES_HOSTNAME=localhost
NEXT_PUBLIC_API_IMAGES_PORT=8080
